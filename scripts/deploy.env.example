RG="rg-flask-sql-auth"
LOCATION="westeurope"
APP_PLAN="plan-flask-sql-auth"
WEBAPP_NAME="app-flask-sql-auth-weeu-01"
SQL_SERVER_NAME="sql-flask-sql-auth-weeu-01"
SQL_DB_NAME="appdb"

SQL_AAD_ADMIN_NAME="<replace with display name>"
SQL_AAD_ADMIN_OBJECT_ID="<replace with object ID>"
SQL_AAD_ADMIN_PRINCIPAL_TYPE="User"

APP_PLAN_SKU="F1"
SQL_DB_EDITION="GeneralPurpose"
SQL_DB_FAMILY="Gen5"
SQL_DB_CAPACITY="2"
SQL_DB_COMPUTE_MODEL="Serverless"
SQL_DB_AUTO_PAUSE_DELAY="60"
SQL_DB_BACKUP_REDUNDANCY="Local"
SQL_DB_FREE_LIMIT_EXHAUSTION_BEHAVIOR="AutoPause"
RUNTIME="PYTHON|3.12"

# Optional overrides:
# AAD_APP_NAME="app-${WEBAPP_NAME}"
# AAD_APP_CLIENT_ID=""
# AAD_APP_OBJECT_ID=""
# AAD_APP_CLIENT_SECRET=""
# AAD_APP_REDIRECT_URI="https://${WEBAPP_NAME}.azurewebsites.net/.auth/login/aad/callback"
# FLASK_SECRET_KEY=""
# PACKAGE_PATH="/tmp/${WEBAPP_NAME}.zip"
# AZURE_CONFIG_DIR="/tmp/.azure-${USER}"
# SKIP_ZIP_DEPLOY="false"
# SKIP_BROWSE="false"
